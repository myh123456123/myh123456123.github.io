<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>高铁之旅 · 昆明→重庆</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #1a5276;
            --primary-light: #2980b9;
            --accent: #e74c3c;
            --gold: #f39c12;
            --bg: #f8f9fa;
            --card-bg: #ffffff;
            --text: #2c3e50;
            --text-light: #7f8c8d;
            --border: #e0e6ed;
            --shadow: 0 4px 20px rgba(0,0,0,0.08);
            --shadow-hover: 0 8px 30px rgba(0,0,0,0.12);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
        }

        /* ===== NAV ===== */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
            border-bottom: 1px solid var(--border);
            transition: box-shadow 0.3s;
        }

        nav.scrolled {
            box-shadow: 0 2px 20px rgba(0,0,0,0.1);
        }

        .nav-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 64px;
        }

        .logo {
            font-size: 20px;
            font-weight: 700;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .logo svg {
            width: 28px;
            height: 28px;
        }

        .nav-links {
            display: flex;
            gap: 32px;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-light);
            font-size: 14px;
            font-weight: 500;
            transition: color 0.3s;
            position: relative;
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: var(--primary);
        }

        .nav-links a.active::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 100%;
            height: 2px;
            background: var(--primary);
            border-radius: 1px;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px;
        }

        .menu-toggle span {
            display: block;
            width: 24px;
            height: 2px;
            background: var(--text);
            margin: 5px 0;
            transition: 0.3s;
        }

        /* ===== HERO ===== */
        .hero {
            margin-top: 64px;
            background: linear-gradient(135deg, #1a5276 0%, #2980b9 50%, #3498db 100%);
            padding: 80px 24px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.05) 1px, transparent 1px);
            background-size: 40px 40px;
            animation: drift 20s linear infinite;
        }

        @keyframes drift {
            to { transform: translate(40px, 40px); }
        }

        .hero-content {
            position: relative;
            z-index: 1;
        }

        .hero h1 {
            font-size: 42px;
            color: #fff;
            font-weight: 700;
            margin-bottom: 12px;
            letter-spacing: 2px;
        }

        .hero .route {
            font-size: 24px;
            color: rgba(255,255,255,0.85);
            font-weight: 300;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
        }

        .route-arrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--gold);
        }

        .route-arrow svg {
            width: 32px;
            height: 32px;
            animation: trainMove 2s ease-in-out infinite;
        }

        @keyframes trainMove {
            0%, 100% { transform: translateX(0); }
            50% { transform: translateX(8px); }
        }

        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 48px;
            margin-top: 40px;
        }

        .hero-stat {
            text-align: center;
            color: #fff;
        }

        .hero-stat .num {
            font-size: 32px;
            font-weight: 700;
        }

        .hero-stat .label {
            font-size: 13px;
            opacity: 0.7;
            margin-top: 4px;
        }

        /* ===== SECTIONS ===== */
        .section {
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 24px;
        }

        .section-title {
            text-align: center;
            margin-bottom: 48px;
        }

        .section-title h2 {
            font-size: 28px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 8px;
        }

        .section-title p {
            color: var(--text-light);
            font-size: 15px;
        }

        .section-title .line {
            width: 40px;
            height: 3px;
            background: var(--gold);
            margin: 12px auto 0;
            border-radius: 2px;
        }

        /* ===== SCHEDULE TABLE ===== */
        .schedule-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--card-bg);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: var(--shadow);
        }

        .schedule-table thead {
            background: var(--primary);
            color: #fff;
        }

        .schedule-table th {
            padding: 16px 20px;
            text-align: left;
            font-weight: 600;
            font-size: 14px;
            letter-spacing: 0.5px;
        }

        .schedule-table td {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        .schedule-table tbody tr {
            transition: background 0.2s;
        }

        .schedule-table tbody tr:hover {
            background: #f0f7ff;
        }

        .schedule-table tbody tr:last-child td {
            border-bottom: none;
        }

        .train-no {
            font-weight: 700;
            color: var(--primary);
            font-size: 15px;
        }

        .time-dep {
            color: var(--accent);
            font-weight: 600;
            font-size: 16px;
        }

        .time-arr {
            color: #27ae60;
            font-weight: 600;
            font-size: 16px;
        }

        .duration {
            color: var(--text-light);
            font-size: 13px;
        }

        .price {
            font-weight: 700;
            color: var(--accent);
        }

        .status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status.on-time {
            background: #e8f8f0;
            color: #27ae60;
        }

        .status.delayed {
            background: #fef5e7;
            color: #f39c12;
        }

        /* ===== STATION INFO ===== */
        .stations-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }

        .station-card {
            background: var(--card-bg);
            border-radius: 12px;
            padding: 32px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .station-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
        }

        .station-card .tag {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 16px;
        }

        .tag.departure {
            background: #eaf2f8;
            color: var(--primary-light);
        }

        .tag.arrival {
            background: #e8f8f0;
            color: #27ae60;
        }

        .station-card h3 {
            font-size: 22px;
            margin-bottom: 8px;
        }

        .station-card .sub {
            color: var(--text-light);
            font-size: 13px;
            margin-bottom: 20px;
        }

        .station-info-list {
            list-style: none;
        }

        .station-info-list li {
            padding: 8px 0;
            border-bottom: 1px dashed var(--border);
            font-size: 14px;
            display: flex;
            justify-content: space-between;
        }

        .station-info-list li:last-child {
            border-bottom: none;
        }

        .station-info-list .label {
            color: var(--text-light);
        }

        .station-info-list .value {
            font-weight: 600;
        }

        /* ===== BOOKS (FEATURED) ===== */
        .books-section {
            background: linear-gradient(180deg, #f0f4f8 0%, var(--bg) 100%);
            padding: 60px 0;
        }

        .books-section .section {
            padding-top: 0;
            padding-bottom: 0;
        }

        .books-section .section-title h2 {
            font-size: 32px;
        }

        .books-section .section-title .badge {
            display: inline-block;
            background: var(--gold);
            color: #fff;
            padding: 4px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .books-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
        }

        .book-card {
            background: var(--card-bg);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: transform 0.3s, box-shadow 0.3s;
            border: 1px solid var(--border);
            cursor: pointer;
        }

        .book-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-hover);
        }

        .book-cover {
            height: 220px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .book-cover .book-visual {
            width: 120px;
            height: 170px;
            border-radius: 4px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 16px;
            text-align: center;
            color: #fff;
            box-shadow: 4px 4px 15px rgba(0,0,0,0.2);
            position: relative;
            transition: transform 0.3s;
        }

        .book-card:hover .book-visual {
            transform: scale(1.05) rotate(-2deg);
        }

        .book-visual::after {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            width: 6px;
            height: 100%;
            background: rgba(0,0,0,0.15);
            border-radius: 4px 0 0 4px;
        }

        .book-visual .book-icon {
            font-size: 28px;
            margin-bottom: 8px;
        }

        .book-visual .book-title-text {
            font-size: 13px;
            font-weight: 700;
            line-height: 1.4;
        }

        .book-visual .book-author-text {
            font-size: 10px;
            opacity: 0.8;
            margin-top: 6px;
        }

        .book-info {
            padding: 20px;
        }

        .book-info h4 {
            font-size: 15px;
            font-weight: 700;
            margin-bottom: 6px;
            line-height: 1.4;
        }

        .book-info .author {
            font-size: 12px;
            color: var(--text-light);
            margin-bottom: 8px;
        }

        .book-info .desc {
            font-size: 12px;
            color: var(--text-light);
            line-height: 1.6;
            margin-bottom: 12px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .book-info .book-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .book-info .rating {
            color: var(--gold);
            font-size: 13px;
            font-weight: 600;
        }

        .book-info .book-price {
            color: var(--accent);
            font-weight: 700;
            font-size: 16px;
        }

        .book-tag {
            position: absolute;
            top: 12px;
            right: 12px;
            background: var(--accent);
            color: #fff;
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
        }

        .featured-book {
            grid-column: span 2;
            display: grid;
            grid-template-columns: 280px 1fr;
            background: var(--card-bg);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: var(--shadow);
            border: 2px solid var(--gold);
            position: relative;
        }

        .featured-book .book-cover {
            height: 100%;
            min-height: 260px;
            background: #f0f4f8;
        }

        .featured-book .book-visual {
            width: 150px;
            height: 210px;
        }

        .featured-book .book-info {
            padding: 32px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .featured-book .book-info h4 {
            font-size: 20px;
            margin-bottom: 10px;
        }

        .featured-book .book-info .desc {
            -webkit-line-clamp: 3;
            font-size: 13px;
            margin-bottom: 16px;
        }

        .featured-badge {
            position: absolute;
            top: 16px;
            left: 16px;
            background: var(--gold);
            color: #fff;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 700;
            z-index: 2;
        }

        .btn {
            display: inline-block;
            padding: 10px 24px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-primary {
            background: var(--primary);
            color: #fff;
        }

        .btn-primary:hover {
            background: var(--primary-light);
            transform: translateY(-2px);
        }

        .btn-outline {
            background: transparent;
            color: var(--primary);
            border: 1px solid var(--primary);
        }

        .btn-outline:hover {
            background: var(--primary);
            color: #fff;
        }

        .btn-gold {
            background: var(--gold);
            color: #fff;
        }

        .btn-gold:hover {
            background: #e67e22;
        }

        .book-info .btn-row {
            display: flex;
            gap: 12px;
            margin-top: auto;
        }

        /* ===== ATTRACTIONS ===== */
        .attractions-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        .attraction-card {
            background: var(--card-bg);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .attraction-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
        }

        .attraction-img {
            height: 180px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            position: relative;
        }

        .attraction-img .overlay-text {
            position: absolute;
            bottom: 12px;
            left: 12px;
            background: rgba(0,0,0,0.6);
            color: #fff;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
        }

        .attraction-info {
            padding: 20px;
        }

        .attraction-info h4 {
            font-size: 17px;
            margin-bottom: 6px;
        }

        .attraction-info p {
            font-size: 13px;
            color: var(--text-light);
            line-height: 1.6;
            margin-bottom: 12px;
        }

        .attraction-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
        }

        .attraction-meta .distance {
            color: var(--primary-light);
            font-weight: 600;
        }

        .attraction-meta .rating {
            color: var(--gold);
        }

        /* ===== MEAL ORDERING ===== */
        .meals-section {
            background: #fff;
            padding: 60px 0;
        }

        .meals-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
        }

        .meal-card {
            background: var(--bg);
            border-radius: 12px;
            padding: 24px;
            text-align: center;
            border: 1px solid var(--border);
            transition: transform 0.3s, box-shadow 0.3s;
            cursor: pointer;
            position: relative;
        }

        .meal-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow);
        }

        .meal-card.selected {
            border-color: var(--primary);
            background: #f0f7ff;
        }

        .meal-card .meal-emoji {
            font-size: 48px;
            margin-bottom: 12px;
            display: block;
        }

        .meal-card h4 {
            font-size: 15px;
            margin-bottom: 6px;
        }

        .meal-card .meal-desc {
            font-size: 12px;
            color: var(--text-light);
            margin-bottom: 12px;
        }

        .meal-card .meal-price {
            font-size: 18px;
            font-weight: 700;
            color: var(--accent);
            margin-bottom: 12px;
        }

        .meal-card .add-btn {
            width: 100%;
            padding: 8px;
            border: 1px solid var(--primary);
            background: transparent;
            color: var(--primary);
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .meal-card .add-btn:hover {
            background: var(--primary);
            color: #fff;
        }

        .meal-card .add-btn.added {
            background: #27ae60;
            border-color: #27ae60;
            color: #fff;
        }

        .meal-card .meal-tag {
            position: absolute;
            top: 12px;
            right: 12px;
            background: var(--accent);
            color: #fff;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 600;
        }

        /* ===== CART BAR ===== */
        .cart-bar {
            position: fixed;
            bottom: -80px;
            left: 0;
            right: 0;
            background: var(--primary);
            color: #fff;
            padding: 16px 24px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 24px;
            z-index: 999;
            transition: bottom 0.4s ease;
            box-shadow: 0 -4px 20px rgba(0,0,0,0.2);
        }

        .cart-bar.show {
            bottom: 0;
        }

        .cart-bar .cart-info {
            font-size: 15px;
            font-weight: 600;
        }

        .cart-bar .cart-total {
            font-size: 20px;
            font-weight: 700;
            color: var(--gold);
        }

        .cart-bar .checkout-btn {
            padding: 10px 32px;
            background: var(--gold);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
        }

        .cart-bar .checkout-btn:hover {
            background: #e67e22;
        }

        /* ===== FOOTER ===== */
        footer {
            background: var(--primary);
            color: rgba(255,255,255,0.7);
            padding: 40px 24px;
            text-align: center;
            font-size: 14px;
        }

        footer .footer-links {
            display: flex;
            justify-content: center;
            gap: 32px;
            margin-bottom: 20px;
            list-style: none;
        }

        footer .footer-links a {
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            transition: color 0.3s;
        }

        footer .footer-links a:hover {
            color: #fff;
        }

        /* ===== MODAL ===== */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 2000;
            justify-content: center;
            align-items: center;
            padding: 24px;
        }

        .modal-overlay.show {
            display: flex;
        }

        .modal {
            background: #fff;
            border-radius: 16px;
            max-width: 500px;
            width: 100%;
            max-height: 80vh;
            overflow-y: auto;
            padding: 32px;
            position: relative;
            animation: modalIn 0.3s ease;
        }

        @keyframes modalIn {
            from { transform: scale(0.9); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }

        .modal-close {
            position: absolute;
            top: 16px;
            right: 16px;
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: var(--text-light);
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.3s;
        }

        .modal-close:hover {
            background: var(--bg);
        }

        .modal h3 {
            font-size: 22px;
            margin-bottom: 8px;
        }

        .modal .modal-subtitle {
            color: var(--text-light);
            font-size: 14px;
            margin-bottom: 24px;
        }

        .modal .detail-row {
            display: flex;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        .modal .detail-row .d-label {
            width: 80px;
            color: var(--text-light);
            flex-shrink: 0;
        }

        .modal .detail-row .d-value {
            font-weight: 600;
        }

        /* ===== SCROLL ANIMATIONS ===== */
        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        .fade-up.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 1024px) {
            .books-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .featured-book {
                grid-column: span 2;
            }

            .meals-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .nav-links {
                display: none;
                position: absolute;
                top: 64px;
                left: 0;
                right: 0;
                background: #fff;
                flex-direction: column;
                padding: 16px 24px;
                gap: 16px;
                border-bottom: 1px solid var(--border);
            }

            .nav-links.open {
                display: flex;
            }

            .menu-toggle {
                display: block;
            }

            .hero h1 {
                font-size: 28px;
            }

            .hero .route {
                font-size: 18px;
                flex-direction: column;
                gap: 8px;
            }

            .hero-stats {
