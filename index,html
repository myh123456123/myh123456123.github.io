    <!-- BOOK MODAL -->
    <div class="modal-overlay" id="bookModal">
        <div class="modal">
            <button class="modal-close" onclick="closeBookModal()">✕</button>
            <h3 id="modalTitle"></h3>
            <div class="modal-subtitle" id="modalSubtitle"></div>
            <div id="modalContent"></div>
            <div style="margin-top:24px; display:flex; gap:12px;">
                <button class="btn btn-gold" style="flex:1;">立即购买</button>
                <button class="btn btn-outline" style="flex:1;" onclick="closeBookModal()">关闭</button>
            </div>
        </div>
    </div>

    <script>
        // ===== NAV =====
        const navbar = document.getElementById('navbar');
        const menuToggle = document.getElementById('menuToggle');
        const navLinks = document.getElementById('navLinks');

        window.addEventListener('scroll', () => {
            navbar.classList.toggle('scrolled', window.scrollY > 10);
        });

        menuToggle.addEventListener('click', () => {
            navLinks.classList.toggle('open');
        });

        // Active nav link
        const sections = document.querySelectorAll('section[id], .books-section');
        const navItems = document.querySelectorAll('.nav-links a');

        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(section => {
                const top = section.offsetTop - 100;
                if (scrollY >= top) {
                    current = section.getAttribute('id');
                }
            });
            navItems.forEach(a => {
                a.classList.remove('active');
                if (a.getAttribute('href') === '#' + current) {
                    a.classList.add('active');
                }
            });
        });

        // ===== SCROLL ANIMATIONS =====
        const fadeEls = document.querySelectorAll('.fade-up');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.1 });

        fadeEls.forEach(el => observer.observe(el));

        // ===== MEAL ORDERING =====
        let cart = [];

        function toggleMeal(btn) {
            const card = btn.closest('.meal-card');
            const name = card.dataset.name;
            const price = parseInt(card.dataset.price);

            if (btn.classList.contains('added')) {
                btn.classList.remove('added');
                btn.textContent = '加入订单';
                card.classList.remove('selected');
                cart = cart.filter(item => item.name !== name);
            } else {
                btn.classList.add('added');
                btn.textContent = '已添加 ✓';
                card.classList.add('selected');
                cart.push({ name, price });
            }

            updateCart();
        }

        function updateCart() {
            const cartBar = document.getElementById('cartBar');
            const cartCount = document.getElementById('cartCount');
            const cartTotal = document.getElementById('cartTotal');

            if (cart.length > 0) {
                cartBar.classList.add('show');
                cartCount.textContent = cart.length;
                cartTotal.textContent = cart.reduce((sum, item) => sum + item.price, 0);
            } else {
                cartBar.classList.remove('show');
            }
        }

        function checkout() {
            if (cart.length === 0) return;
            const total = cart.reduce((sum, item) => sum + item.price, 0);
            const items = cart.map(i => i.name).join('、');
            alert(`🎉 订单提交成功！\n\n餐品：${items}\n合计：¥${total}\n\n餐食将在列车上送至您的座位。`);
            // Reset
            cart = [];
            document.querySelectorAll('.meal-card').forEach(card => {
                card.classList.remove('selected');
                const btn = card.querySelector('.add-btn');
                btn.classList.remove('added');
                btn.textContent = '加入订单';
            });
            updateCart();
        }

        // ===== BOOK MODAL =====
        const booksData = [
            {
                title: '中国高铁经济地理',
                subtitle: '王建国 著 · 中信出版集团 · 2024年 · 368页',
                details: [
                    ['ISBN', '978-7-5217-xxxx-x'],
                    ['开本', '16开'],
                    ['装帧', '精装'],
                    ['定价', '¥68.00'],
                    ['评分', '★★★★★ 9.4分（3,286条评价）'],
                    ['简介', '本书系统分析了中国高铁网络对区域经济格局的深远影响，从城市群的崛起到产业带的重构，全方位解读"高铁经济带"的形成逻辑。包含大量一手调研数据与实地案例。']
                ]
            },
            {
                title: '高铁技术全书',
                subtitle: '李明 著 · 人民交通出版社 · 512页',
                details: [
                    ['ISBN', '978-7-114-xxxx-x'],
                    ['开本', '16开'],
                    ['装帧', '平装'],
                    ['定价', '¥89.00'],
                    ['评分', '★★★★☆ 8.9分（2,156条评价）'],
                    ['简介', '全面介绍高铁核心技术，涵盖轨道工程、动车组设计、列控系统、牵引供电等关键领域，配有大量工程图纸与照片。']
                ]
            },
            {
                title: '轨道上的中国',
                subtitle: '张华 著 · 商务印书馆 · 2024年 · 288页',
                details: [
                    ['ISBN', '978-7-100-xxxx-x'],
                    ['开本', '32开'],
                    ['装帧', '精装'],
                    ['定价', '¥56.00'],
                    ['评分', '★★★★★ 9.2分（4,521条评价）'],
                    ['简介', '以人文视角讲述中国铁路百年变迁，从蒸汽机车到复兴号的时代跨越，穿插铁路工人的真实故事。']
                ]
            },
            {
                title: '高速铁路工程概论',
                subtitle: '陈伟 著 · 科学出版社 · 456页',
                details: [
                    ['ISBN', '978-7-03-xxxx-x'],
                    ['开本', '16开'],
                    ['装帧', '平装'],
                    ['定价', '¥75.00'],
                    ['评分', '★★★★☆ 8.7分（1,892条评价）'],
                    ['简介', '高校经典教材，系统讲解高铁线路规划、桥梁隧道、轨道结构、电气化等工程知识，适合工程类专业学生。']
                ]
            },
            {
                title: '大国重器：中国高铁崛起之路',
                subtitle: '赵磊 著 · 人民出版社 · 320页',
                details: [
                    ['ISBN', '978-7-01-xxxx-x'],
                    ['开本', '16开'],
                    ['装帧', '精装'],
                    ['定价', '¥52.00'],
                    ['评分', '★★★★★ 9.1分（5,678条评价）'],
                    ['简介', '记录中国高铁从引进消化吸收再创新到引领世界的辉煌历程，采访多位高铁工程师与管理者。']
                ]
            }
        ];

        function openBookModal(index) {
            const book = booksData[index];
            const modal = document.getElementById('bookModal');
            document.getElementById('modalTitle').textContent = book.title;
            document.getElementById('modalSubtitle').textContent = book.subtitle;

            let html = '';
            book.details.forEach(([label, value]) => {
                html += `<div class="detail-row">
                    <span class="d-label">${label}</span>
                    <span class="d-value">${value}</span>
                </div>`;
            });
            document.getElementById('modalContent').innerHTML = html;
            modal.classList.add('show');
        }

        function closeBookModal() {
            document.getElementById('bookModal').classList.remove('show');
        }

        document.getElementById('bookModal').addEventListener('click', (e) => {
            if (e.target === e.currentTarget) closeBookModal();
        });

        // Close modal on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeBookModal();
        });
    </script>
</body>
</html>
